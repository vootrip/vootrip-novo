{
	"compilerOptions": {
		"composite": true,
		"tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
		"target": "ES2022",
		"useDefineForClassFields": true,
		"lib": ["ES2022", "DOM", "DOM.Iterable"],
		"module": "ESNext",
		"types": ["vite/client", "node"],
		"skipLibCheck": true,

		/* Path Aliases */
		"baseUrl": ".",
		"paths": {
			"@/*": ["./src/*"]
		},

		/* Bundler mode */
		"moduleResolution": "bundler",
		"allowImportingTsExtensions": true,
		"verbatimModuleSyntax": false,
		"moduleDetection": "force",
		"noEmit": true,
		"jsx": "react-jsx",

		/* Linting */
		"strict": false,
		"noUnusedLocals": false,
		"noUnusedParameters": false,
		"noImplicitAny": false,
		"noFallthroughCasesInSwitch": false
	},
	"include": ["src"],
	// `_ExamplePage.tsx` is a documentation file shown to the AI agent as a canonical
	// "how to write a page" reference. It deliberately queries an `items` table that
	// only exists once a migration runs, so under TypeScript's empty `Database` type
	// it would fail `tsc`. Excluding it keeps `npm run build` green for AI-scaffolded
	// projects while still leaving the file on disk as a reference.
	"exclude": ["src/pages/_ExamplePage.tsx"]
}
